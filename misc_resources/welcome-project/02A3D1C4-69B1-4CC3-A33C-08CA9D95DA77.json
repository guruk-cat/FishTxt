{"type":"doc","content":[{"type":"heading","attrs":{"level":1},"content":[{"type":"text","text":"Click on me!"}]},{"type":"paragraph","content":[{"type":"text","text":"Welcome to FishTxt."}]},{"type":"paragraph","content":[{"type":"text","text":"This is an example project to help you familiarize yourself with the app. Right now, you are in the "},{"type":"text","marks":[{"type":"bold"}],"text":"Editor"},{"type":"text","text":", where you can see and edit "},{"type":"text","marks":[{"type":"bold"}],"text":"Blobs"},{"type":"text","text":", which are rich text files that are loaded into HTML and CSS. "}]},{"type":"paragraph","content":[{"type":"text","text":"To go back to the "},{"type":"text","marks":[{"type":"bold"}],"text":"Dashboard"},{"type":"text","text":", press the "},{"type":"text","marks":[{"type":"bold"}],"text":"ESC key"},{"type":"text","text":" or click the "},{"type":"text","marks":[{"type":"bold"}],"text":"X button"},{"type":"text","text":" on the top-right corner to exit the editor."}]},{"type":"paragraph"}]}